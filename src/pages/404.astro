---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <section
    class="flex flex-col items-center justify-center px-4 py-24 text-center"
  >
    <h1 class="text-6xl font-black text-primary sm:text-8xl">404</h1>
    <p class="mt-4 text-xl text-muted">Página no encontrada</p>
    <p class="mt-2 text-muted">
      La página que buscas no existe o ha sido movida.
    </p>
    <a
      href="/"
      class="mt-8 inline-flex items-center gap-2 rounded-lg bg-primary px-6 py-3 text-white font-semibold no-underline transition-transform hover:scale-105"
    >
      Volver al inicio
    </a>
  </section>
</Layout>
