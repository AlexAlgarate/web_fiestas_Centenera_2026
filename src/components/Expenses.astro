---
import { getExpensesData } from '../lib/expenses';

const PALETTE = [
  '#962000',
  '#d4a017',
  '#2f6f4e',
  '#1f3a5f',
  '#a85c32',
  '#6b7280',
];

function colorFor(index: number): string {
  return PALETTE[index % PALETTE.length];
}

const { categories, grandTotal, updatedAt } = await getExpensesData();

const sortedCategories = [...categories].sort((a, b) => b.total - a.total);

const hasData = grandTotal > 0;

let cumulative = 0;
const gradientStops = sortedCategories
  .map((cat, index) => {
    if (cat.total <= 0) return null;
    const share = (cat.total / grandTotal) * 100;
    const start = cumulative;
    cumulative += share;
    return `${colorFor(index)} ${start}% ${cumulative}%`;
  })
  .filter((stop): stop is string => stop !== null);

const gradientCSS = hasData
  ? gradientStops.join(', ')
  : 'var(--clr-border) 0% 100%';

function formatCurrency(value: number): string {
  const sign = value < 0 ? '-' : '';
  const [intPart, decPart] = Math.abs(value).toFixed(2).split('.');
  const grouped = intPart.replace(/\B(?=(\d{3})+(?!\d))/g, '.');
  return `${sign}${grouped},${decPart} €`;
}

const percentageFormatter = new Intl.NumberFormat('es-ES', {
  minimumFractionDigits: 2,
  maximumFractionDigits: 2,
});

const formattedDate = new Date(`${updatedAt}T00:00:00`).toLocaleDateString(
  'es-ES',
  { day: 'numeric', month: 'long', year: 'numeric' },
);

const totalCount = sortedCategories.reduce((sum, c) => sum + c.count, 0);

const chartAriaLabel = hasData
  ? `Gráfico circular de gastos por tipo: ${sortedCategories
      .filter((c) => c.total > 0)
      .map(
        (c) =>
          `${c.name} ${percentageFormatter.format(c.percentage)} por ciento`,
      )
      .join(', ')}.`
  : 'Todavía no hay gastos registrados.';
---

<section
  id="expenses"
  class="w-full bg-white px-4 py-10 sm:py-8 max-[480px]:py-6"
>
  <div class="max-w-300 mx-auto">
    <div class="mb-8 text-center sm:mb-6">
      <h2
        class="m-0 text-text text-2xl sm:text-4xl font-bold tracking-[-0.02em]"
      >
        Cuentas de las Fiestas
      </h2>
      <p class="mt-3 text-sm text-muted">
        Datos actualizados el {formattedDate}
      </p>
    </div>

    <div
      class="flex flex-col items-center gap-10 lg:flex-row lg:items-center lg:justify-center lg:gap-16"
    >
      <div class="shrink-0">
        <div
          class="donut-chart"
          style={`background: conic-gradient(${gradientCSS});`}
          role="img"
          aria-label={chartAriaLabel}
        >
          <div class="donut-hole">
            {
              hasData ? (
                <>
                  <span class="donut-total">{formatCurrency(grandTotal)}</span>
                  <span class="donut-total-label">Total</span>
                </>
              ) : (
                <>
                  <span class="donut-total">—</span>
                  <span class="donut-total-label">Sin datos aún</span>
                </>
              )
            }
          </div>
        </div>
      </div>

      <div
        class="w-full max-w-md overflow-x-auto rounded-card border border-border"
      >
        <table class="w-full min-w-full border-collapse text-sm">
          <caption class="sr-only">
            Desglose de gastos de las fiestas por tipo
          </caption>
          <thead>
            <tr class="bg-surface text-text">
              <th scope="col" class="px-4 py-3 text-left font-semibold">
                Tipo de gasto
              </th>
              <th scope="col" class="px-3 py-3 text-right font-semibold">
                Nº gastos
              </th>
              <th scope="col" class="px-3 py-3 text-right font-semibold">
                Total
              </th>
              <th scope="col" class="px-4 py-3 text-right font-semibold">
                %
              </th>
            </tr>
          </thead>
          <tbody>
            {
              sortedCategories.map((cat, index) => (
                <tr class="border-t border-border">
                  <td class="px-4 py-3 text-text">
                    <span
                      class="legend-swatch"
                      style={`background:${colorFor(index)};`}
                    />
                    {cat.name}
                  </td>
                  <td class="px-3 py-3 text-right text-muted">{cat.count}</td>
                  <td class="px-3 py-3 text-right font-medium text-text whitespace-nowrap">
                    {formatCurrency(cat.total)}
                  </td>
                  <td class="px-4 py-3 text-right text-muted whitespace-nowrap">
                    {percentageFormatter.format(cat.percentage)}%
                  </td>
                </tr>
              ))
            }
          </tbody>
          <tfoot>
            <tr
              class="border-t-2 border-border bg-surface font-semibold text-text"
            >
              <td class="px-4 py-3">Total</td>
              <td class="px-3 py-3 text-right">{totalCount}</td>
              <td class="px-3 py-3 text-right whitespace-nowrap">
                {formatCurrency(grandTotal)}
              </td>
              <td class="px-4 py-3 text-right whitespace-nowrap">
                {percentageFormatter.format(hasData ? 100 : 0)}%
              </td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>
  </div>
</section>

<style>
  .donut-chart {
    position: relative;
    width: clamp(190px, 55vw, 280px);
    aspect-ratio: 1 / 1;
    border-radius: 50%;
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.14);
  }

  .donut-hole {
    position: absolute;
    inset: 18%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--clr-white);
    box-shadow: inset 0 2px 6px rgba(0, 0, 0, 0.06);
    padding: 8px;
    text-align: center;
  }

  .donut-total {
    font-size: clamp(1.05rem, 4vw, 1.4rem);
    font-weight: 700;
    line-height: 1.15;
    color: var(--clr-text);
  }

  .donut-total-label {
    margin-top: 2px;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--clr-muted);
  }

  .legend-swatch {
    display: inline-block;
    width: 10px;
    height: 10px;
    margin-right: 8px;
    border-radius: 50%;
    vertical-align: middle;
  }
</style>
