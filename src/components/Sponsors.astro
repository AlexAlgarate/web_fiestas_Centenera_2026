---
import sponsorsData from '../data/sponsors.json';

interface Sponsor {
  name: string;
  image: string;
  link: string;
}

const sponsors = sponsorsData.sponsors as Sponsor[];

const images = import.meta.glob<{ default: { src: string } }>(
  '../assets/sponsors/*.{jpg,png,PNG}',
  { eager: true },
);
---

<section
  id="sponsors"
  class="w-full bg-white px-4 py-10 sm:py-8 max-[480px]:py-6"
>
  <div class="max-w-300 mx-auto">
    <div class="mb-8 text-center sm:mb-6">
      <h2
        class="m-0 text-text text-2xl sm:text-4xl font-bold tracking-[-0.02em]"
      >
        Colaboradores
      </h2>
    </div>

    <div
      class="grid grid-cols-1 gap-6 sm:grid-cols-2 sm:gap-4 lg:grid-cols-3 lg:gap-3"
    >
      {
        sponsors.map((sponsor, index) => {
          const imagePath = `../assets/sponsors/${sponsor.image}`;
          const image = images[imagePath];

          if (!image) {
            console.warn(`Image not found: ${sponsor.image}`);
            return null;
          }

          const Tag = sponsor.link ? 'a' : 'div';
          const linkProps = sponsor.link
            ? {
                href: sponsor.link,
                target: '_blank',
                rel: 'noopener noreferrer',
              }
            : {};

          return (
            <Tag
              class="
                sponsor-card relative flex aspect-3/2 items-center justify-center
                overflow-hidden rounded-2xl bg-surface no-underline
                shadow-[0_4px_12px_rgba(0,0,0,0.08)] transition-all duration-300 
                ease-in-out hover:-translate-y-1 
                hover:shadow-[0_12px_24px_rgba(0,0,0,0.15)]"
              title={sponsor.name}
              {...linkProps}
            >
              <img
                src={image?.default.src}
                alt={sponsor.name}
                loading="lazy"
                fetchpriority={index === 0 ? 'high' : 'auto'}
                decoding="async"
                class="h-full w-full object-contain p-4 transition-transform duration-300 ease-in-out group-hover:scale-105"
              />
            </Tag>
          );
        })
      }
    </div>
  </div>
</section>
