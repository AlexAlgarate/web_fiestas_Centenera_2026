---
import '../styles/global.css';

import background from '../assets/background.svg';
import centeneraPhoto from '../assets/imagen-centenera.jpeg';
---

<div class="flex flex-col font-sans">
  <img id="background" src={background.src} alt="" fetchpriority="high" />
  <div>
    <section id="hero">
      <div class="hero-media">
        <h1 class="title">Centenera</h1>
        <div class="w-full overflow-hidden leading-0">
          <img
            src={centeneraPhoto.src}
            alt="Vista de Centenera"
            loading="eager"
            decoding="async"
            fetchpriority="high"
            class="block w-full h-auto max-h-[60vh] object-cover object-center"
          />
        </div>
      </div>
      <h2
        class="mt-6 mx-4 mb-4 font-pocheon font-semibold
        text-3xl sm:text-4xl md:text-5xl leading-none
        tracking-wider text-(--clr-text) text-center pl-[1em] md:mt-8"
      >
        Horarios Fiestas 2026
      </h2>
    </section>
  </div>
</div>

<style>
  #background {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    filter: blur(80px);
  }

  #hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .hero-media {
    position: relative;
    width: 100%;
  }

  .title {
    position: absolute;
    z-index: 2;
    margin: 0;
    font-family: 'Bridge', serif;
    color: var(--clr-primary);
    font-size: clamp(2.5rem, 8vw, 6rem);
    font-weight: 900;
    line-height: 1;
    letter-spacing: 0.08em;
    margin-right: -0.08em;
    padding-left: 0.48em;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.25);
    top: 4%;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    text-align: center;
    box-sizing: border-box;
  }

  @media (min-width: 768px) {
    .title {
      font-size: clamp(3rem, 7vw, 6rem);
      top: 6%;
    }

    .photo-wrapper img {
      max-height: 65vh;
    }
  }

  @media (min-width: 1024px) {
    .title {
      top: 8%;
    }
  }
</style>
