---
import '../styles/global.css';

import background from '../assets/background.svg';
import centeneraPhoto from '../assets/imagen-centenera.jpeg';
---

<div class="flex flex-col font-sans">
  <img
    class="fixed inset-0 w-full h-full z-[-1] blur-[80px]"
    src={background.src}
    alt=""
    fetchpriority="high"
  />
  <div>
    <section class="flex flex-col items-center w-full">
      <div class="relative w-full">
        <h1
          class="absolute z-10 m-0 font-bridge text-(--clr-primary) text-5xl sm:text-6xl
            md:text-7xl lg:text-8xl font-black leading-none tracking-[0.08em]
            mr-[-0.08em] pl-[0.48em] top-[4%] md:top-[6%] lg:top-[8%] left-1/2
            w-full text-center box-border -translate-x-1/2
            [text-shadow:0_12px_18px_rgba(255,255,255,0.85)]"
        >
          Centenera
        </h1>
        <div class="w-full overflow-hidden leading-0">
          <img
            src={centeneraPhoto.src}
            alt="Vista de Centenera"
            loading="eager"
            decoding="async"
            fetchpriority="high"
            class="block w-full h-auto max-h-[60vh] md:max-h-[65vh] object-cover object-center"
          />
        </div>
      </div>
      <h2
        class="mt-6 mx-4 mb-4 font-pocheon font-semibold
        text-3xl sm:text-4xl md:text-5xl leading-none
        tracking-wider text-(--clr-text) text-center pl-[1em] md:mt-8"
      >
        Horarios Fiestas 2026
      </h2>
    </section>
  </div>
</div>

<style></style>
